            <script src="/isInViewport.js"></script>
        <script src="/jquery.jkey.js"></script>
        <script>
          $(document).jkey('j', true, function(){
            if(!$(":focus").is("input,textarea,select")) {
              if ($("div.row h1").is(':in-viewport')) {
                $([document.documentElement, document.body]).animate({
                  scrollTop: $("#maincontent div.wrapper").first().offset().top - 55
                }, 300);
              } else {
                $([document.documentElement, document.body]).animate({
                  scrollTop: $("#maincontent div.wrapper:in-viewport(200)").parent().next().offset().top + 23
                }, 300);
              }
            }
          });
          $(document).jkey('k', true, function(){
	    if(!$(":focus").is("input,textarea,select")) {
              $([document.documentElement, document.body]).animate({
                scrollTop: $("#maincontent div.wrapper:in-viewport(200)").parent().prev().prev().offset().top - 55
              }, 300);
	    }
          });
          $(document).jkey('s', true, function(){
            if(!$(":focus").is("input,textarea,select")) {
              $("#search_input").focus();
            }
          });
          $(document).jkey('?', true, function(){
            if(!$(":focus").is("input,textarea,select"))
              $("#keyshelp").modal("show");
          });
          $(document).jkey('b', true, function(){
	    if(!$(":focus").is("input,textarea,select"))
              $('html, body').animate({scrollTop:$(document).height()}, 'fast');
          });
          $(document).jkey('t', true, function(){
	    if(!$(":focus").is("input,textarea,select"))
              $('html, body').animate({scrollTop:0}, 'fast');
          });
        </script>
      </script>

